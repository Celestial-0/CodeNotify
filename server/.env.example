# ==============================================
# CodeNotify - Environment Configuration
# ==============================================
# Copy this file to .env.local and fill in the values

# ==============================================
# Server Configuration
# ==============================================
PORT=3000
NODE_ENV=development

# ==============================================
# Database Configuration
# ==============================================
# For local development (default MongoDB port)
MONGO_URI=mongodb://localhost:27017/codenotify

# For MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/codenotify?retryWrites=true&w=majority

# ==============================================
# Authentication
# ==============================================
# Generate a strong secret key (at least 10 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_this_in_production

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000

# ==============================================
# Contest Platform APIs
# ==============================================
# Codeforces API endpoint (optional, can be left empty for now)
CODEFORCES_API=https://codeforces.com/api

# LeetCode API endpoint (optional, can be left empty for now)
LEETCODE_API=https://leetcode.com/graphql

# ==============================================
# Contest Sync Scheduler Configuration
# ==============================================
# Enable/disable automatic contest syncing
CONTEST_SYNC_ENABLED=true

# Cron expression for sync interval
# Examples:
#   - "0 */6 * * *"  = Every 6 hours
#   - "0 */3 * * *"  = Every 3 hours
#   - "0 */12 * * *" = Every 12 hours
#   - "0 0 * * *"    = Once daily at midnight
CONTEST_SYNC_INTERVAL=0 */6 * * *

# Enable/disable old contest cleanup
CONTEST_CLEANUP_ENABLED=true

# Number of days to keep finished contests (default: 90)
CONTEST_CLEANUP_DAYS=90

# ==============================================
# Notification Configuration
# ==============================================
# Enable/disable notifications
NOTIFICATIONS_ENABLED=true

# Time window (in hours) before contest start to send notifications
# Example: 24 = notify users 24 hours before contest starts
NOTIFICATION_WINDOW_HOURS=24

# ==============================================
# Email Notifications (Resend)
# ==============================================
# Get your API key from: https://resend.com/api-keys
# Sign up at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Email sender address (must be verified in Resend)
# Format: "Name <email@yourdomain.com>"
EMAIL_FROM=CodeNotify <noreply@yourdomain.com>

# ==============================================
# WhatsApp Cloud API (Meta Business)
# ==============================================
# Get these from: https://developers.facebook.com/apps
# Optional - only needed when implementing WhatsApp notifications

# Your WhatsApp Business API Access Token
WHATSAPP_API_KEY=your_whatsapp_api_access_token

# Your WhatsApp Phone Number ID
WHATSAPP_PHONE_ID=your_whatsapp_phone_id

# Your WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ==============================================
# Discord Bot Configuration
# ==============================================
# Get these from: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to Bot section and create a bot
# 3. Copy the token and application details

# Enable/disable Discord notifications (set to false to disable)
ENABLE_DISCORD=true

# Discord Application ID (from General Information)
DISCORD_APPLICATION_ID=your_discord_application_id

# Discord Public Key (from General Information - for webhook verification)
DISCORD_PUBLIC_KEY=your_discord_public_key

# Discord Bot Token (from Bot section)
DISCORD_BOT_TOKEN=your_discord_bot_token

# Discord OAuth2 (for user account linking)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/api/users/integrations/discord/callback

# ==============================================
# Telegram Bot Configuration
# ==============================================
# Get your bot token from @BotFather on Telegram
# 1. Message @BotFather with /newbot
# 2. Follow the prompts to create your bot
# 3. Copy the token provided

# Enable/disable Telegram notifications (set to false to disable)
ENABLE_TELEGRAM=true

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Bot Username (without @, e.g., "CodeNotifyBot")
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Webhook secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# ==============================================
# Webhook Configuration
# ==============================================
# Base URL for webhooks (must be HTTPS in production)
WEBHOOK_BASE_URL=http://localhost:3000

# ==============================================
# Notification Retry Configuration
# ==============================================
# Enable/disable automatic retry of failed notifications
ENABLE_NOTIFICATION_RETRY=true

# Maximum number of retry attempts for failed notifications
NOTIFICATION_MAX_RETRIES=3

# Delay in minutes between retry attempts
NOTIFICATION_RETRY_DELAY_MINUTES=5
